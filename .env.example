# -----------------------------------------------------------------------------
# Core server configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
OPENAI_API_KEY=
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Public application URL
# Set this separately for Preview and Production in Vercel.
# -----------------------------------------------------------------------------
VITE_APP_URL=https://your-project.vercel.app

# -----------------------------------------------------------------------------
# Clerk authentication
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Same-origin proxy endpoint used by the existing Clerk configuration.
VITE_CLERK_PROXY_URL=https://your-project.vercel.app/api/__clerk

# -----------------------------------------------------------------------------
# Sanity blog content
# -----------------------------------------------------------------------------
VITE_SANITY_PROJECT_ID=c0tinigu
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-05-28

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_REGISTRATION_FEE_PRICE_ID=

# -----------------------------------------------------------------------------
# Resend email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=ImmoVia365 <noreply@example.com>

# -----------------------------------------------------------------------------
# Google Cloud Storage
# The credentials value must be the complete service-account JSON on one line.
# Vercel stores it safely as an encrypted environment variable.
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
PRIVATE_OBJECT_DIR=/your-bucket/private
